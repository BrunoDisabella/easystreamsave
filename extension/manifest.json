{
  "manifest_version": 3,
  "name": "Easy Stream Save",
  "description": "Detect videos and stream playlists on the current page, preview direct files, and download available media without invasive ads.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Easy Stream Save",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
