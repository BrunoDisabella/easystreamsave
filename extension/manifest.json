{
  "manifest_version": 3,
  "name": "Easy Stream Save",
  "description": "Detect downloadable video files and stream playlists on the current page.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Easy Stream Save"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.svg",
    "32": "icons/icon-32.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  }
}
